@model BookHive.ViewModels.Cart.CartViewModel

@{
    ViewData["Title"] = "Shopping Cart";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h1 class="h3 mb-1">Your cart</h1>
        <p class="text-muted mb-0">Review the books you plan to order.</p>
    </div>
    <a asp-controller="Books" asp-action="Index" class="btn btn-outline-secondary">Continue shopping</a>
</div>

@if (TempData["StatusMessage"] is string statusMessage)
{
    <div class="alert alert-success">@statusMessage</div>
}

@if (!Model.Items.Any())
{
    <div class="alert alert-info">Your cart is empty.</div>
}
else
{
    <div class="card shadow-sm">
        <div class="table-responsive">
            <table class="table align-middle mb-0">
                <thead>
                    <tr>
                        <th>Book</th>
                        <th>Price</th>
                        <th>Quantity</th>
                        <th>Total</th>
                        <th class="text-end">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model.Items)
                    {
                        <tr>
                            <td>
                                <div class="d-flex align-items-center gap-3">
                                    @if (!string.IsNullOrWhiteSpace(item.CoverImagePath))
                                    {
                                        <img src="@item.CoverImagePath" alt="@item.Title cover" class="rounded" style="width: 52px; height: 72px; object-fit: cover;" />
                                    }
                                    <div>
                                        <a asp-controller="Books" asp-action="Details" asp-route-id="@item.BookId" class="fw-semibold text-decoration-none">@item.Title</a>
                                        <div class="text-muted">@item.Author</div>
                                    </div>
                                </div>
                            </td>
                            <td>@item.UnitPrice.ToString("C")</td>
                            <td style="max-width: 180px;">
                                <form asp-action="UpdateQuantity" method="post" class="d-flex gap-2" data-api-cart-form data-api-endpoint="/api/cart/items" data-api-method="PUT" data-reload-on-success="true">
                                    <input type="hidden" name="cartItemId" value="@item.Id" />
                                    <input type="number" name="quantity" value="@item.Quantity" min="0" class="form-control" />
                                    <button type="submit" class="btn btn-outline-primary">Update</button>
                                </form>
                            </td>
                            <td>@item.LineTotal.ToString("C")</td>
                            <td class="text-end">
                                <form asp-action="Remove" method="post" class="d-inline" data-api-cart-form data-api-endpoint="/api/cart/items" data-api-method="DELETE" data-reload-on-success="true">
                                    <input type="hidden" name="cartItemId" value="@item.Id" />
                                    <button type="submit" class="btn btn-outline-danger">Remove</button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
                <tfoot>
                    <tr>
                        <th colspan="3" class="text-end">Order total</th>
                        <th>@Model.TotalAmount.ToString("C")</th>
                        <th class="text-end">
                            <a asp-controller="Orders" asp-action="Checkout" class="btn btn-primary">Proceed to checkout</a>
                        </th>
                    </tr>
                </tfoot>
            </table>
        </div>
    </div>
}
