@model BookHive.ViewModels.Books.BookCatalogViewModel

@{
    ViewData["Title"] = "Books";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h1 class="h3 mb-1">Browse books</h1>
        <p class="text-muted mb-0">Explore the current BookHive catalog.</p>
    </div>
</div>

<form method="get" class="card card-body shadow-sm mb-4">
    <div class="row g-3 align-items-end">
        <div class="col-md-4">
            <label for="searchTerm" class="form-label">Search</label>
            <input id="searchTerm" name="searchTerm" value="@Model.SearchTerm" class="form-control" placeholder="Search by title or author" />
        </div>
        <div class="col-md-3">
            <label for="category" class="form-label">Category</label>
            <select id="category" name="category" class="form-select">
                <option value="">All categories</option>
                @foreach (var category in Model.Categories)
                {
                    <option value="@category" selected="@(category == Model.Category)">@category</option>
                }
            </select>
        </div>
        <div class="col-md-2">
            <label for="minPrice" class="form-label">Min price</label>
            <input id="minPrice" name="minPrice" value="@Model.MinPrice" type="number" step="0.01" class="form-control" />
        </div>
        <div class="col-md-2">
            <label for="maxPrice" class="form-label">Max price</label>
            <input id="maxPrice" name="maxPrice" value="@Model.MaxPrice" type="number" step="0.01" class="form-control" />
        </div>
        <div class="col-md-1 d-grid">
            <button type="submit" class="btn btn-primary">Go</button>
        </div>
    </div>
</form>

<div class="row g-4">
    @if (!Model.Books.Any())
    {
        <div class="col-12">
            <div class="alert alert-info mb-0">No books matched the current search and filter settings.</div>
        </div>
    }
    else
    {
        @foreach (var book in Model.Books)
        {
            <div class="col-md-6 col-xl-4">
                <div class="card h-100 shadow-sm">
                    @if (!string.IsNullOrWhiteSpace(book.CoverImagePath))
                    {
                        <img src="@book.CoverImagePath" class="card-img-top" alt="@book.Title cover" style="height: 320px; object-fit: cover;" />
                    }
                    <div class="card-body d-flex flex-column">
                        <span class="text-muted small text-uppercase">@book.Category</span>
                        <h2 class="h5 mt-2">@book.Title</h2>
                        <p class="mb-1 text-muted">by @book.Author</p>
                        <p class="fw-semibold mb-2">@book.Price.ToString("C")</p>
                        <p class="card-text text-muted flex-grow-1">@book.Description</p>
                        <a asp-controller="Books" asp-action="Details" asp-route-id="@book.Id" class="btn btn-outline-primary mt-3">View details</a>
                    </div>
                </div>
            </div>
        }
    }
</div>
