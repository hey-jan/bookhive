@model BookHive.ViewModels.Orders.CheckoutViewModel

@{
    ViewData["Title"] = "Checkout";
}

<div class="row g-4">
    <div class="col-lg-7">
        <div class="card shadow-sm">
            <div class="card-body p-4">
                <h1 class="h3 mb-3">Checkout</h1>
                <p class="text-muted">Confirm your shipping address and review the order before placing it.</p>

                <form asp-action="Checkout" method="post">
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                    <div class="mb-3">
                        <label asp-for="ShippingAddress" class="form-label"></label>
                        <textarea asp-for="ShippingAddress" class="form-control" rows="4"></textarea>
                        <span asp-validation-for="ShippingAddress" class="text-danger"></span>
                    </div>

                    <button type="submit" class="btn btn-primary">Place order</button>
                </form>
            </div>
        </div>
    </div>
    <div class="col-lg-5">
        <div class="card shadow-sm">
            <div class="card-body p-4">
                <h2 class="h5 mb-3">Order summary</h2>
                <ul class="list-group list-group-flush mb-3">
                    @foreach (var item in Model.Items)
                    {
                        <li class="list-group-item d-flex justify-content-between px-0">
                            <div>
                                <div class="fw-semibold">@item.Title</div>
                                <div class="text-muted small">Qty: @item.Quantity</div>
                            </div>
                            <span>@item.LineTotal.ToString("C")</span>
                        </li>
                    }
                </ul>
                <div class="d-flex justify-content-between fw-semibold">
                    <span>Total</span>
                    <span>@Model.TotalAmount.ToString("C")</span>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
