@model BookHive.ViewModels.Orders.OrderSummaryViewModel

@{
    ViewData["Title"] = "Order Summary";
}

<div class="row justify-content-center">
    <div class="col-lg-8">
        <div class="card shadow-sm">
            <div class="card-body p-4">
                <h1 class="h3 mb-2">Order placed</h1>
                <p class="text-muted">Order #@Model.OrderId was submitted on @Model.PlacedAtUtc.ToLocalTime().ToString("MMMM dd, yyyy h:mm tt").</p>

                <div class="mb-4">
                    <div class="fw-semibold">Shipping address</div>
                    <div>@Model.ShippingAddress</div>
                </div>

                <table class="table align-middle">
                    <thead>
                        <tr>
                            <th>Book</th>
                            <th>Quantity</th>
                            <th>Unit price</th>
                            <th>Total</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model.Items)
                        {
                            <tr>
                                <td>@item.BookTitle</td>
                                <td>@item.Quantity</td>
                                <td>@item.UnitPrice.ToString("C")</td>
                                <td>@item.LineTotal.ToString("C")</td>
                            </tr>
                        }
                    </tbody>
                    <tfoot>
                        <tr>
                            <th colspan="3" class="text-end">Order total</th>
                            <th>@Model.TotalAmount.ToString("C")</th>
                        </tr>
                    </tfoot>
                </table>

                <a asp-controller="Books" asp-action="Index" class="btn btn-primary">Continue browsing</a>
            </div>
        </div>
    </div>
</div>
