@{
    ViewData["Title"] = "Home";
}

<div class="px-4 py-5 my-5 text-center">
    <h1 class="display-4 fw-bold">BookHive</h1>
    <div class="col-lg-6 mx-auto">
        <p class="lead mb-4">Browse curated titles, manage your profile, and order books from a single storefront built with ASP.NET Core and EF Core.</p>
        <div class="d-grid gap-2 d-sm-flex justify-content-sm-center">
            <a asp-controller="Account" asp-action="Register" class="btn btn-primary btn-lg px-4 gap-3">Create account</a>
            <a asp-controller="Account" asp-action="Login" class="btn btn-outline-secondary btn-lg px-4">Login</a>
        </div>
    </div>
</div>
