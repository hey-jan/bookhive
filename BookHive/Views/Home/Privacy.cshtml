@{
    ViewData["Title"] = "Privacy Policy";
}
<section class="surface-panel p-4 p-lg-5">
    <h1 class="mb-3">@ViewData["Title"]</h1>
    <p class="text-secondary">BookHive stores only the account, cart, and order information needed to operate the bookstore experience.</p>
    <p class="text-secondary mb-0">Profile images and book cover uploads are saved on the local application host, and account passwords are stored through ASP.NET Core Identity password hashing rather than as plain text.</p>
</section>
